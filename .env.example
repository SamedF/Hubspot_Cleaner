PORT=3000
HUBSPOT_PRIVATE_APP_TOKEN=replace_with_private_app_access_token
HUBSPOT_APP_CLIENT_SECRET=replace_with_private_app_client_secret

# Start safe first.
DRY_RUN=true

# Recommended first live mode is close, not archive.
# close = marks thread CLOSED
# archive = moves thread to trash and HubSpot permanently deletes after 30 days
ACTION=close

# Safety controls
REQUIRE_ICS_ATTACHMENT=true
ONLY_IF_THREAD_OPEN=true
IGNORE_INBOX_IDS=
IGNORE_CHANNEL_IDS=

# Optional regex filters. Leave blank to handle any incoming message that includes a .ics attachment.
# Comma-separated JavaScript regex patterns.
SENDER_ALLOWLIST_REGEX=(calendar|meeting|noreply|no-reply|scheduler|booking|invite)
SUBJECT_ALLOWLIST_REGEX=(accepted|declined|tentative|meeting confirmation|calendar|invitation|rescheduled|updated invitation)
BODY_ALLOWLIST_REGEX=(accepted|declined|tentative|calendar invite|meeting confirmation|invitation)

# Runtime controls
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=15000
MAX_HUBSPOT_RETRIES=3
DEDUPE_TTL_MS=86400000
